<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Bocchi58 - My Blogs</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-[#0d1b1e] text-gray-100 font-handwriting flex flex-col items-center justify-center min-h-screen">
    
    <!-- 头像 -->
    <div class="flex flex-col items-center space-y-3">
      <img 
        src="/avatar.png" 
        alt="avatar" 
        class="w-28 h-28 rounded-full border-4 border-blue-400 shadow-lg"
      />
      <h1 class="text-2xl font-bold">Bocchi58</h1>
      <p class="text-gray-400">Like River!</p>
    </div>

    <!-- 分割线 -->
    <div class="w-40 border-t border-gray-600 my-5"></div>

    <!-- 图标导航 -->
    <div class="flex space-x-6 text-2xl">
      <a href="#" class="hover:text-teal-400"><i class="fas fa-paper-plane"></i></a>
      <a href="#" class="hover:text-green-400"><i class="fas fa-book"></i></a>
      <a href="#" class="hover:text-lime-400"><i class="fas fa-gamepad"></i></a>
      <a href="#" class="hover:text-red-400"><i class="fas fa-power-off"></i></a>
      <a href="#" class="hover:text-sky-400"><i class="fas fa-envelope"></i></a>
    </div>

    <!-- 底部 -->
    <footer class="absolute bottom-5 text-sm text-gray-400 text-center">
      <p>
        Made with <span class="text-pink-500">❤</span> by <span class="text-white font-semibold">Motues</span><br/>
        Powered by Astro<br/>
        <a href="#" class="hover:text-gray-200">1</a>
      </p>
    </footer>

    <!-- FontAwesome 图标库 -->
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
