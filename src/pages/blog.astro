---
title: "Home"
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Bocchi58 - My Blogs</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap');
      body {
        font-family: 'Poppins', sans-serif;
      }

      /* 发光动画 */
      @keyframes pulse-glow {
        0%, 100% {
          box-shadow: 0 0 20px rgba(59, 130, 246, 0.4);
        }
        50% {
          box-shadow: 0 0 40px rgba(59, 130, 246, 0.8);
        }
      }

      /* 图标浮动旋转 */
      .icon-hover:hover {
        transform: scale(1.2) rotate(10deg);
        text-shadow: 0 0 20px currentColor;
      }
      .icon-hover {
        transition: all 0.25s ease-in-out;
      }
    </style>
  </head>

  <body class="bg-gradient-to-br from-[#0a0f1f] via-[#111827] to-[#1e293b] text-gray-100 flex flex-col items-center justify-center min-h-screen relative overflow-hidden">

    <!-- 背景光环 -->
    <div class="absolute -top-32 -left-32 w-96 h-96 bg-blue-500 rounded-full blur-3xl opacity-20 animate-pulse"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-teal-500 rounded-full blur-3xl opacity-20 animate-pulse"></div>

    <!-- 头像与昵称 -->
    <div class="flex flex-col items-center space-y-3 z-10">
      <div class="relative">
        <div class="absolute inset-0 rounded-full bg-blue-500 opacity-50 blur-lg animate-pulse-glow"></div>
        <img 
          src="/avatar.png"
          alt="avatar"
          class="relative w-32 h-32 rounded-full border-4 border-blue-400 shadow-lg z-10"
        />
      </div>
      <h1 class="text-3xl font-bold bg-gradient-to-r from-blue-400 to-teal-300 bg-clip-text text-transparent">
        Bocchi58
      </h1>
      <p class="text-gray-400 text-sm tracking-wide">Like River — Calm but Deep</p>
    </div>

    <!-- 分割线 -->
    <div class="w-40 border-t border-gray-700 my-8"></div>

    <!-- 图标导航 -->
    <div class="flex space-x-8 text-3xl z-10">
      <a href="#" class="text-blue-400 icon-hover"><i class="fas fa-paper-plane"></i></a>
      <a href="#" class="text-green-400 icon-hover"><i class="fas fa-book"></i></a>
      <a href="#" class="text-yellow-400 icon-hover"><i class="fas fa-gamepad"></i></a>
      <a href="#" class="text-red-400 icon-hover"><i class="fas fa-power-off"></i></a>
      <a href="#" class="text-sky-400 icon-hover"><i class="fas fa-envelope"></i></a>
    </div>

    <!-- 底部 -->
    <footer class="absolute bottom-5 text-sm text-gray-500 text-center z-10">
      <p>
        Made with <span class="text-pink-500">❤</span> by 
        <span class="text-white font-semibold">Motues</span><br/>
        Powered by <span class="text-blue-400">Astro</span><br/>
        <a href="#" class="hover:text-gray-200">1</a>
      </p>
    </footer>

    <!-- FontAwesome 图标库 -->
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
  </body>
</html>
